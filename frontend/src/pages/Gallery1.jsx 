import { useEffect, useState } from 'react';
import { getGallery, createGalleryItem, deleteGalleryItem } from '../services/galleryService';

export default function Gallery() {
  const [items, setItems] = useState([]);
  const [name, setName] = useState('');
  const [file, setFile] = useState(null);

  const fetchGallery = async () => {
    const res = await getGallery();
    setItems(res.data);
  };

  useEffect(() => { fetchGallery(); }, []);

  const handleAdd = async () => {
    if (!name || !file) return;
    const formData = new FormData();
    formData.append('name', name);
    formData.append('file', file);
    await createGalleryItem(formData);
    fetchGallery();
    setName('');
    setFile(null);
  };

  const handleDelete = async (id) => {
    await deleteGalleryItem(id);
    fetchGallery();
  };

  return (
    <div>
      <h1 className="text-2xl font-bold mb-6 text-white">Galeria</h1>
      <div className="bg-gray-800 p-4 rounded-lg mb-6">
        <input type="text" placeholder="Emri" value={name} onChange={(e) => setName(e.target.value)} className="p-2 rounded mr-2" />
        <input type="file" onChange={(e) => setFile(e.target.files[0])} className="mr-2" />
        <button onClick={handleAdd} className="bg-green-600 px-4 py-2 rounded text-white">Shto</button>
      </div>
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        {items.map(item => (
          <div key={item.id} className="bg-gray-800 p-4 rounded-lg">
            <p className="text-white font-semibold">{item.name}</p>
            <p className="text-gray-400 text-sm">{item.status}</p>
            <button onClick={() => handleDelete(item.id)} className="bg-red-600 px-3 py-1 rounded mt-2 text-sm">Fshij</button>
          </div>
        ))}
      </div>
    </div>
  );
}